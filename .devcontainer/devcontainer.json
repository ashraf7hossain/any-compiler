{
  "name": "C/C++ Dev Environment",
  "dockerComposeFile": "../docker-compose.yaml",
  "service": "c-dev",
  "workspaceFolder": "/usr/src/app",
  "customizations": {
    "vscode": {
      "settings": {
        "C_Cpp.default.intelliSenseMode": "linux-gcc-x64"
      },
      "extensions": [
        "ms-vscode.cpptools",
        "ms-vscode.cpptools-extension-pack",
        "ms-vscode.makefile-tools"
      ]
    }
  }
}
